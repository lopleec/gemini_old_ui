{
  "manifest_version": 3,
  "name": "Gemini Web UI Customizer",
  "version": "1.0",
  "description": "UI theme overrides for gemini.google.com: custom light/dark surfaces, sidebar spacing fixes, and targeted visual polish.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ]
}
